# Variables d'environnement — copier ce fichier vers .env.local
# Aucune variable n'est requise pour lancer la Phase 1.
# Les valeurs ci-dessous sont prévues pour les phases suivantes.

# Base de données (Phase 2 — PostgreSQL + Prisma)
# DATABASE_URL="postgresql://user:password@localhost:5432/comptacount"

# Authentification (Phase 2 — NextAuth, provider GitHub)
# AUTH_SECRET=""
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""
